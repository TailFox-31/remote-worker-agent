{
  "name": "remote-worker-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Platform-neutral remote worker pull agent for EJClaw control plane.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "start": "tsx src/index.ts",
    "start:once": "tsx src/index.ts --once"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
