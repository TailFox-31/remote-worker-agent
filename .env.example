# EJClaw remote worker control plane
# Same-machine Windows -> WSL example:
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8787
CONTROL_PLANE_TOKEN=replace-with-shared-secret

# Worker identity
WORKER_ID=worker-win-01
WORKER_DISPLAY_NAME=Windows Worker 01

# Capability tokens (comma-separated)
# Example:
# - os:windows
# - tool:codex
# - tool:claude-code
# - tool:unity-editor
# - tool:git
WORKER_CAPABILITIES=os:windows,tool:codex,tool:git
WORKER_MAX_CONCURRENCY=1

# Default provider when job requirements do not force a specific one
WORKER_DEFAULT_PROVIDER=codex

# dry-run: skeleton mode without real CLI execution
# strict: run the real executor binding (codex implemented, claude-code still skeleton)
WORKER_EXECUTION_MODE=dry-run

# Optional codex executor settings
# WORKER_CODEX_BIN=codex
# WORKER_CODEX_MODEL=gpt-5.4-codex
# CODEX_HOME=C:/Users/you/.codex
# OPENAI_API_KEY=

# Polling / local paths
WORKER_POLL_INTERVAL_MS=5000
WORKER_WORKSPACE_ROOT=.workspaces
WORKER_SESSION_STORE=.sessions/store.json

# Optional git auth for private repos
# Example (Windows):
# WORKER_GIT_SSH_COMMAND=ssh -i C:/Users/you/.ssh/id_ed25519 -o IdentitiesOnly=yes
# WORKER_GIT_TERMINAL_PROMPT=0
# WORKER_SSH_AUTH_SOCK=
# WORKER_GIT_ASKPASS=
